{
  "name": "ocs-cli",
  "version": "0.1.0",
  "description": "OCS-CLI — AI Agent 浏览器自动化工具，复用 ocsjs 识别逻辑",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "ocs": "./dist/cli/index.js"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsx src/cli/index.ts",
    "start": "node dist/cli/index.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "commander": "^13.1.0",
    "cors": "^2.8.5",
    "express": "^5.1.0",
    "playwright-core": "^1.52.0",
    "ws": "^8.18.0",
    "zod": "^3.24.0",
    "chalk": "^5.4.1"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/node": "^22.15.0",
    "@types/ws": "^8.18.0",
    "tsup": "^8.4.0",
    "tsx": "^4.19.0",
    "typescript": "^5.8.0",
    "vitest": "^3.1.0"
  },
  "engines": {
    "node": ">=20"
  },
  "license": "MIT"
}
